{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-print",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "shell:allow-open",
    "store:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$HOME/**/*" }, { "path": "/**/*" }]
    }
  ]
}
